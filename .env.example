# --- STT ---
# STT provider: openai | local
VOICE_STT_PROVIDER=openai
# OpenAI STT model (examples: whisper-1, gpt-4o-mini-transcribe)
OPENAI_STT_MODEL=whisper-1
# local whisper model (used only when VOICE_STT_PROVIDER=local)
WHISPER_MODEL=base

# --- LLM summary/action extraction ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional behavior ---
VOICE_JOURNAL_LANGUAGE=ko
VOICE_JOURNAL_MAX_FILES=10
