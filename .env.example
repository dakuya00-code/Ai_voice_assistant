# --- STT ---
# STT provider: gemini | local
VOICE_STT_PROVIDER=gemini
# Gemini STT model
GEMINI_STT_MODEL=gemini-1.5-flash
# local whisper model (used only when VOICE_STT_PROVIDER=local)
WHISPER_MODEL=base

# --- LLM summary/action extraction ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Audio pre-processing (ffmpeg filter chain) ---
VOICE_DENOISE_ENABLED=1
VOICE_DENOISE_LEVEL=20

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional behavior ---
VOICE_JOURNAL_LANGUAGE=ko
VOICE_JOURNAL_MAX_FILES=10
